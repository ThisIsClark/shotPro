# Basketball Shooting Form Analyzer - Environment Variables Example
# Copy this file to .env and fill in your values

# ===== Supabase Configuration =====
# Get these from your Supabase Dashboard > Settings > API

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Public anon key - used by frontend for authentication
SUPABASE_ANON_KEY=

# Service role key - used by backend for database operations (higher privileges)
# WARNING: Keep this secret! Never expose it to the frontend
SUPABASE_SERVICE_KEY=

# ===== Application Settings =====
DEBUG=true
APP_NAME="Basketball Shooting Form Analyzer"

# ===== Upload Limits =====
MAX_VIDEO_SIZE_MB=50
MAX_VIDEO_DURATION_SECONDS=10

# ===== Analysis Settings =====
TARGET_FPS=30
MIN_DETECTION_CONFIDENCE=0.5
MIN_TRACKING_CONFIDENCE=0.5